# URL de l'engine FastAPI (Railway). En local: http://localhost:8000
NEXT_PUBLIC_ENGINE_URL=http://localhost:8000

# --- Supabase (projet partagé strata-scope, région UE) ------------------
NEXT_PUBLIC_SUPABASE_URL=https://yccnnlasjcjuukithguk.supabase.co
# Project Settings -> API Keys
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Clé serveur (jamais exposée au navigateur ; contourne la RLS).
SUPABASE_SERVICE_ROLE_KEY=

# --- adama.ai (génération LLM + RAG, serveur uniquement) ----------------
# Clé OpenAI : génération (gpt-4o) ET embeddings de requête
# (text-embedding-3-small, 1024 dim). Jamais préfixée NEXT_PUBLIC_.
OPENAI_API_KEY=
# Modèle utilisé par adama.ai. Optionnel (défaut: gpt-4o).
ADAMA_AI_MODEL=gpt-4o
# Retrieval RAG (pgvector via Drizzle). Connection string Supabase,
# Transaction pooler (la même que packages/db/.env). Serveur uniquement.
DATABASE_URL=

# --- GitHub (feed "Shipped", serveur uniquement) -------------------------
# Optionnel. Sans token : 60 req/h (largement assez avec le cache 5 min).
# Avec un fine-grained token lecture seule sur le repo public : 5000 req/h.
GITHUB_TOKEN=

# --- L6 Conversion (modal recruteur) --------------------------------------
# Lien Cal.com embarqué dans le modal, format "handle/event" (ex: adama-diallo/15min).
# Si vide : repli mailto, le modal fonctionne quand même.
NEXT_PUBLIC_CAL_LINK=
# Clé projet PostHog (événement recruiter_intent). Si vide : analytics inactif.
NEXT_PUBLIC_POSTHOG_KEY=
# Hôte PostHog. Défaut : https://eu.i.posthog.com (région UE).
NEXT_PUBLIC_POSTHOG_HOST=

# --- L6 Conversion : Polar (paiements formations + SaaS) ------------------
# URL publique du site (construit les success_url de checkout). En prod,
# Vercel fournit VERCEL_PROJECT_PRODUCTION_URL en repli. En local : localhost.
NEXT_PUBLIC_SITE_URL=
# Environnement Polar : "sandbox" (défaut, pour tester) ou "production".
POLAR_SERVER=sandbox
# Organization Access Token (Polar -> Settings -> Developers). Serveur uniquement.
# Sans lui, le checkout retombe sur /learn/acces (aucune casse).
POLAR_ACCESS_TOKEN=
# Secret de webhook (Polar -> Settings -> Webhooks). Vérification Standard Webhooks.
# Sans lui, la route webhook refuse tout (401) : aucun accès accordé à tort.
POLAR_WEBHOOK_SECRET=
# IDs produits Polar, un par niveau de formation (Polar -> Products).
POLAR_PRODUCT_L1=
POLAR_PRODUCT_L2=
POLAR_PRODUCT_L3=
POLAR_PRODUCT_L4=
# ID produit de l'abonnement SaaS STRATA (essai gratuit L6-T9).
POLAR_PRODUCT_SAAS=

# --- L6 Conversion : Resend (newsletter + emails transactionnels) ---------
# Clé API Resend (resend.com -> API Keys). Serveur uniquement. Sans elle,
# aucun email n'est envoyé et l'inscription newsletter reste sans erreur.
RESEND_API_KEY=
# Expéditeur vérifié dans Resend (domaine validé), ex. "STRATA <no-reply@ton-domaine.fr>".
RESEND_FROM=
# Adresse de réponse (optionnel). Défaut : aucune.
RESEND_REPLY_TO=
# ID de l'audience newsletter (Resend -> Audiences). Sans lui, l'ajout de
# contact est ignoré (l'inscription ne casse pas pour autant).
RESEND_AUDIENCE_ID=

# --- L6 Conversion : Cal.com (confirmation de RDV, optionnel) --------------
# Secret du webhook Cal.com (Cal -> Settings -> Webhooks). Sans lui, la route
# /api/webhooks/cal refuse tout (401) : il suffit de ne pas créer le webhook.
CAL_WEBHOOK_SECRET=

# --- L8-T6 Better Stack (uptime, serveur uniquement) ----------------------
# API token : betterstack.com -> Uptime -> API tokens. Monitor ID : dans
# l'URL du monitor (uptime.betterstack.com/monitors/<id>).
# Si vides : le badge Online retombe sur system_metrics (comportement actuel).
BETTERSTACK_API_TOKEN=
BETTERSTACK_MONITOR_ID=

# --- L5 Contenu / Veille (Sanity) ---------------------------------------
# Projet Sanity (sanity.io -> Project settings). projectId et dataset sont
# publics (préfixe NEXT_PUBLIC_), c'est normal. apiVersion = date figée.
NEXT_PUBLIC_SANITY_PROJECT_ID=
NEXT_PUBLIC_SANITY_DATASET=production
NEXT_PUBLIC_SANITY_API_VERSION=2026-06-01
# Token d'ÉCRITURE (droits Editor). Serveur / job Trigger.dev uniquement,
# jamais préfixé NEXT_PUBLIC_. Sanity -> API -> Tokens.
SANITY_WRITE_TOKEN=

# --- L5 Formations /learn (accès premium) -------------------------------
# Secret de signature du cookie d'accès aux formations (HMAC-SHA256).
# Serveur uniquement, jamais préfixé NEXT_PUBLIC_. Minimum 16 caractères.
# Générer : openssl rand -hex 32. Sans ce secret, aucun accès premium n'est
# accordé (fail-closed) ; les leçons gratuites restent lisibles.
LEARN_ACCESS_SECRET=

# --- L5 Veille (Trigger.dev) --------------------------------------------
# Référence du projet Trigger.dev (proj_xxxx). Utilisée par trigger.config.ts.
# Les secrets du job (OPENAI_API_KEY, SANITY_WRITE_TOKEN, NEXT_PUBLIC_SANITY_*)
# se définissent dans le dashboard Trigger.dev, PAS dans Vercel.
TRIGGER_PROJECT_REF=

# --- Sentry (observabilité) ---------------------------------------------
# DSN public du projet Sentry. Exposé au navigateur, c'est normal.
# Si vide, Sentry reste inactif (aucune erreur n'est envoyée).
NEXT_PUBLIC_SENTRY_DSN=
# Org et projet Sentry (upload des source maps au build).
SENTRY_ORG=
SENTRY_PROJECT=
# Token d'auth Sentry pour l'upload des source maps. Build/CI uniquement.
# A definir dans Vercel, jamais en local commit. https://sentry.io/settings/account/api/auth-tokens/
SENTRY_AUTH_TOKEN=
