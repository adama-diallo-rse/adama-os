# URL de l'engine FastAPI (Railway). En local: http://localhost:8000
NEXT_PUBLIC_ENGINE_URL=http://localhost:8000

# --- Supabase (projet partagé strata-scope, région UE) ------------------
NEXT_PUBLIC_SUPABASE_URL=https://yccnnlasjcjuukithguk.supabase.co
# Project Settings -> API Keys
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Clé serveur (jamais exposée au navigateur ; contourne la RLS).
SUPABASE_SERVICE_ROLE_KEY=

# --- adama.ai (génération LLM, serveur uniquement) ----------------------
# Clé du fournisseur LLM. Jamais préfixée NEXT_PUBLIC_ : reste côté serveur.
OPENAI_API_KEY=
# Modèle utilisé par adama.ai. Optionnel (défaut: gpt-4o).
ADAMA_AI_MODEL=gpt-4o

# --- GitHub (feed "Shipped", serveur uniquement) -------------------------
# Optionnel. Sans token : 60 req/h (largement assez avec le cache 5 min).
# Avec un fine-grained token lecture seule sur le repo public : 5000 req/h.
GITHUB_TOKEN=

# --- L6 Conversion (modal recruteur) --------------------------------------
# Lien Cal.com embarqué dans le modal, format "handle/event" (ex: adama-diallo/15min).
# Si vide : repli mailto, le modal fonctionne quand même.
NEXT_PUBLIC_CAL_LINK=
# Clé projet PostHog (événement recruiter_intent). Si vide : analytics inactif.
NEXT_PUBLIC_POSTHOG_KEY=
# Hôte PostHog. Défaut : https://eu.i.posthog.com (région UE).
NEXT_PUBLIC_POSTHOG_HOST=

# --- Sentry (observabilité) ---------------------------------------------
# DSN public du projet Sentry. Exposé au navigateur, c'est normal.
# Si vide, Sentry reste inactif (aucune erreur n'est envoyée).
NEXT_PUBLIC_SENTRY_DSN=
# Org et projet Sentry (upload des source maps au build).
SENTRY_ORG=
SENTRY_PROJECT=
# Token d'auth Sentry pour l'upload des source maps. Build/CI uniquement.
# A definir dans Vercel, jamais en local commit. https://sentry.io/settings/account/api/auth-tokens/
SENTRY_AUTH_TOKEN=
