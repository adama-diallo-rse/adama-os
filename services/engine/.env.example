# =====================================================================
# services/engine (FastAPI) - variables d'environnement
# En production : definies dans Railway (onglet Variables), jamais commitees.
# En local : copier ce fichier en .env (ignore par git).
# =====================================================================

# Port d'ecoute. Railway l'injecte automatiquement en prod.
# En local, uvicorn utilise 8000 par defaut.
PORT=8000

# Environnement d'execution : development | production
ENVIRONMENT=development

# --- Base de donnees (Supabase, a venir) -----------------------------
